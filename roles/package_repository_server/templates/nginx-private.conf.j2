server {
{% for domain in pkg_server_private_domains %}
    if ($host = {{ domain }}) {
        return 301 https://$host$request_uri;
    }
{% endfor %}

    listen 80;
    server_name {{ pkg_server_private_domains | join(' ') }};

    # Redirect all HTTP requests to HTTPS
    return 301 https://$host$request_uri;
}
{% if pkg_server_ssl_enabled %}

server {
    listen 443 ssl;
    add_header Access-Control-Allow-Origin "*" always;
    server_name {{ pkg_server_private_domains | join(' ') }};
    root {{ pkg_server_base_dir }}/private;
    autoindex on;

    # SSL certificate configuration
    ssl_certificate {{ pkg_server_private_ssl_certificate }};
    ssl_certificate_key {{ pkg_server_private_ssl_certificate_key }};

    # Client certificate verification
    ssl_client_certificate {{ pkg_server_base_dir }}/ca/ca.crt;
    ssl_verify_client on;
    ssl_verify_depth 1;

    # Enhanced SSL security settings
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384';

    # Pass client certificate info to the application
    proxy_set_header X-SSL-Client-S-DN   $ssl_client_s_dn;
    proxy_set_header X-SSL-Client-I-DN   $ssl_client_i_dn;
    proxy_set_header X-SSL-Client-Serial $ssl_client_serial;
    proxy_set_header X-SSL-Client-Verify $ssl_client_verify;

    # Main location block
    location / {
        try_files $uri $uri/ =404;

        # Add client certificate info to response headers (for debugging)
        add_header X-Client-DN $ssl_client_s_dn;
        add_header X-Client-Verify $ssl_client_verify;
    }

    # Certificate download location - restricted by client certificate CN
    location /certs/ {
        alias {{ pkg_server_base_dir }}/clients/;

        # Extract the CN from the client certificate
        set $client_cn "";
        if ($ssl_client_s_dn ~ "CN=([^,]+)") {
            set $client_cn $1;
        }

        # Only allow access to the user's own directory
        try_files /$client_cn$uri /$client_cn$uri/ =403;

        # Disable directory listing for security
        autoindex off;

        # Log access attempts
        access_log /var/log/nginx/cert-access.log;
    }

    # Repository access
    location /debian/ {
        try_files $uri $uri/ =404;
    }

    # Error pages for certificate issues
    error_page 495 496 = @error_no_cert;
    error_page 400 401 403 404 500 502 503 504 = @error_general;

    location @error_no_cert {
        root /var/www/no-cert;
        rewrite ^ /no-cert.html break;
        internal;
    }

    location @error_general {
        return 403 "Access denied. Please contact the repository administrator.";
    }

    # Logging
    access_log /var/log/nginx/private.packages.access.log;
    error_log /var/log/nginx/private.packages.error.log;
}
{% endif %}
