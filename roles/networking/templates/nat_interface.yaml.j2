#jinja2:lstrip_blocks: True
---
network:
  renderer: networkd
  ethernets:
    {{ network_name }}:
      accept-ra: false
      dhcp-identifier: mac
{% if convert_nat_dhcp_to_static %}
      addresses:
        - {{ address }}/{{ prefix }}
#      routes:
#        - to: {{ gateway }}/{{ prefix }}
#          via: {{ gateway }}
{% endif %}
{% if convert_nat_dhcp_to_static %}
      dhcp4: false
{% else %}
      dhcp4: true
      dhcp4-overrides:
        send-hostname: true
        use-hostname: false
{% endif %}
      dhcp6: false
      match:
        macaddress: {{ macaddress }}
      set-name: {{ network_name }}
  version: 2