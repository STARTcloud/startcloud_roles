{{ ansible_managed | comment }}
# MongoDB configuration rendered by the startcloud.startcloud_roles.graylog role.

storage:
  dbPath: /var/lib/mongodb

systemLog:
  destination: file
  logAppend: true
  path: /var/log/mongodb/mongod.log

net:
  port: 27017
  bindIp: {{ graylog_mongodb_bind_ip }}

processManagement:
  timeZoneInfo: /usr/share/zoneinfo
