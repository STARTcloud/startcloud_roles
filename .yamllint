---
# Single collection-root yamllint config. Strict yamllint `default` ruleset with
# two Ansible-practical adjustments. ansible-lint auto-detects this file for its
# `yaml` rule, and standalone `yamllint .` uses it too.
extends: default

rules:
  # Ansible task lines (long module args, Jinja) routinely exceed 80; warn only.
  line-length:
    max: 200
    level: warning
  # Match the house style: booleans must be true/false, not yes/no/on/off.
  truthy:
    allowed-values: ['true', 'false']
